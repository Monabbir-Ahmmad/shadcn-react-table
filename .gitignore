# dependencies
node_modules
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
coverage

# next.js
.next/
out/

# production
build
dist

# turbo
.turbo

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# graphify (knowledge graph)
# Keep the queryable graph + report committed (the graphify workflow in
# CLAUDE.md expects graphify-out/graph.json to exist); ignore the regenerable
# cache, generated viz, and local interpreter/state files.
graphify-out/cache/
graphify-out/cost.json
graphify-out/manifest.json
graphify-out/graph.html
graphify-out/.graphify_*

# Claude Code: share project settings, ignore per-developer local overrides
.claude/settings.local.json